dbExecute(con, "
UPDATE raw.members
SET woonplaats =
UPPER(SUBSTR(LOWER(TRIM(woonplaats)), 1, 1)) ||
SUBSTR(LOWER(TRIM(woonplaats)), 2)
")
dbGetQuery(con,"
SELECT woonplaats, COUNT(*) as aantal
FROM raw.members
GROUP BY woonplaats
ORDER BY aantal DESC
LIMIT 20
")
dbGetQuery(con,"
SELECT DISTINCT woonplaats
FROM raw.members
WHERE LOWER(woonplaats) LIKE '%amersfoort%'
")
