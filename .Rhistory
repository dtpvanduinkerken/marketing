2
) AS totale_omzet,
ROUND(
ABS(SUM(CAST(discount AS DOUBLE))),
2
) AS totale_discount,
COUNT(*) AS aantal_gebruikt,
ROUND(
AVG(CAST(omzet AS DOUBLE)),
2
) AS gemiddelde_omzet
FROM staging.personal_pricing
")
