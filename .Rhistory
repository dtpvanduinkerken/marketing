df <- read.csv("data/raw/members.csv", sep = ";")
df <- df[, 1:5]
df$aanmelddatum    <- as.Date(df$aanmelddatum, format = "%d-%m-%Y")
df$eerste_aankoop  <- as.Date(df$eerste_aankoop, format = "%d-%m-%Y")
df$laatste_aankoop <- as.Date(df$laatste_aankoop, format = "%d-%m-%Y")
df$klantnummer     <- as.integer(df$klantnummer)
df$woonplaats      <- as.character(df$woonplaats)
df$woonplaats[df$woonplaats == ""] <- N
df$aanmelddatum    <- as.Date(df$aanmelddatum, format = "%d-%m-%Y")
df$eerste_aankoop  <- as.Date(df$eerste_aankoop, format = "%d-%m-%Y")
df$laatste_aankoop <- as.Date(df$laatste_aankoop, format = "%d-%m-%Y")
df$klantnummer     <- as.integer(df$klantnummer)
df$woonplaats      <- as.character(df$woonplaats)
df$woonplaats[df$woonplaats == ""] <- NA
str(df)
nrow(df)
dbWriteTable(con, DBI::Id(schema = "raw", table = "members"), df, overwrite = TRUE)
dbGetQuery(con, "DESCRIBE raw.members")
dbGetQuery(con, "SELECT COUNT(*) FROM raw.members")
dbExecute(con, "
CREATE OR REPLACE TABLE mart.members_groei AS
SELECT
DATE_TRUNC('month', aanmelddatum) AS maand,
COUNT(*) AS nieuwe_members
FROM raw.members
WHERE aanmelddatum IS NOT NULL
GROUP BY 1
ORDER BY 1;
")
dbExecute(con, "
CREATE OR REPLACE TABLE mart.members_woonplaats AS
SELECT
woonplaats,
COUNT(*) AS members
FROM raw.members
WHERE woonplaats IS NOT NULL
GROUP BY 1
ORDER BY members DESC;
")
dbExecute(con, "
CREATE OR REPLACE TABLE mart.members_activiteit AS
SELECT
CASE
WHEN laatste_aankoop IS NULL THEN 'Nooit actief'
WHEN DATE_DIFF('day', laatste_aankoop, CURRENT_DATE) <= 365 THEN 'Actief'
ELSE 'Slapend'
END AS status,
COUNT(*) AS aantal
FROM raw.members
GROUP BY 1;
")
dbGetQuery(con, "SELECT * FROM mart.members_groei ORDER BY maand DESC LIMIT 5")
dbGetQuery(con, "SELECT * FROM mart.members_woonplaats LIMIT 5")
dbGetQuery(con, "SELECT * FROM mart.members_activiteit")
